# =============================================================================
# O QUE PREENCHER (você — humano)
# - Quando: uma vez ao criar o projeto (Fase A); revisar na migração Supabase (Fase D)
# - Copie para .env.local (nunca commitar .env.local)
# - DATA_SOURCE deve ser IGUAL a AGENTS.md → Identidade → Fonte de dados
# =============================================================================

# --- Fonte de dados ---
# local     = Dexie/IndexedDB apenas (fase de construção, sem Supabase)
# supabase  = produção com Supabase Auth + PostgreSQL + RLS
DATA_SOURCE=local

# Espelho client-side — deve ser igual a DATA_SOURCE (sync/outbox no browser)
NEXT_PUBLIC_DATA_SOURCE=local

# --- Fuso horário da UI (sempre horário de Brasília por padrão) ---
NEXT_PUBLIC_APP_TIMEZONE=America/Sao_Paulo

# --- Supabase (obrigatório apenas quando DATA_SOURCE=supabase) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- App ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000
